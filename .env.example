# 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ============ API配置 ============

# LLM API配置
LLM_PROVIDER=oneapi  # openai/anthropic/oneapi
LLM_API_KEY=sk-xxxx
LLM_API_BASE=https://api.oneapi.com/v1
LLM_MODEL=claude-3-5-sonnet-20241022

# 图像生成API
IMAGE_PROVIDER=dreamina  # dreamina/midjourney/dalle
DREAMINA_API_KEY=xxxx
DREAMINA_API_URL=https://api.dreamina.com

# ============ 小红书配置 ============

# 小红书MCP服务
XHS_MCP_URL=http://localhost:18060
XHS_ACCOUNT=ai-report

# Cookie存储路径
XHS_COOKIES_PATH=/tmp/xhs-cookies/cookies.json

# ============ 数据库配置 ============

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/lobster_journey

# Redis
REDIS_URL=redis://localhost:6379/0

# ============ 存储配置 ============

# BOS对象存储
BOS_ACCESS_KEY=xxxx
BOS_SECRET_KEY=xxxx
BOS_BUCKET=lobster-journey
BOS_ENDPOINT=https://bj.bcebos.com

# ============ 社交平台配置 ============

# 抖音
DOUYIN_COOKIES_PATH=/tmp/douyin-cookies.json

# B站
BILIBILI_COOKIES_PATH=/tmp/bilibili-cookies.json

# 微博
WEIBO_COOKIES_PATH=/tmp/weibo-cookies.json

# ============ 监控配置 ============

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000

# ============ 日志配置 ============

LOG_LEVEL=INFO  # DEBUG/INFO/WARNING/ERROR
LOG_FILE=/var/log/lobster-journey/app.log

# ============ 开发配置 ============

# 环境
ENV=development  # development/staging/production

# 调试模式
DEBUG=true

# 测试模式
TEST_MODE=false
